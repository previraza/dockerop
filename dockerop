import textwrap
from pathlib import Path
from datetime import datetime

APP_DIR = ".dockerop"
CONFIG_FILE = "config.json"
VERSION = "0.3.11"
DEFAULT_OPENCODE_IMAGE = "ghcr.io/anomalyco/opencode"
DEFAULT_INSTALL_METHOD = "image"
DEFAULT_NETWORK_MODE = "bridge"
DEFAULT_SESSION_MODE = "isolated"


def project_root() -> Path:
    return Path.cwd().resolve()


def dockerop_dir(root: Path) -> Path:
    return root / APP_DIR


def config_path(root: Path) -> Path:
    return dockerop_dir(root) / CONFIG_FILE


def short_hash(value: str, size: int = 10) -> str:
    return hashlib.sha256(value.encode("utf-8")).hexdigest()[:size]


def slug(value: str) -> str:
    clean = "".join(char.lower() if char.isalnum() else "-" for char in value)
    clean = "-".join(part for part in clean.split("-") if part)
    return clean[:32] or "project"


def random_machine_id() -> str:
    return secrets.token_hex(16)


def host_ids() -> tuple[int | None, int | None]:
    if hasattr(os, "getuid") and hasattr(os, "getgid"):
        return os.getuid(), os.getgid()
    return None, None


def yaml_quote(value: str | Path) -> str:
    return "'" + str(value).replace("'", "''") + "'"


def load_config(root: Path) -> dict:
    with config_path(root).open("r", encoding="utf-8") as handle:
        return json.load(handle)


def write_file(path: Path, content: str, force: bool) -> None:
    if path.exists() and not force:
        return
    path.write_text(content, encoding="utf-8")


def ensure_gitignore(root: Path) -> None:
    gitignore = root / ".gitignore"
    entry = f"{APP_DIR}/\n"
    if gitignore.exists():
        content = gitignore.read_text(encoding="utf-8")
        if any(line.strip() == f"{APP_DIR}/" for line in content.splitlines()):
            return
        if content and not content.endswith("\n"):
            content += "\n"
        gitignore.write_text(content + entry, encoding="utf-8")
    else:
        gitignore.write_text(entry, encoding="utf-8")


def dockerop_gitignore() -> str:
    return textwrap.dedent(
        """\
        # Local dockerop runtime state.
        state/
        *.log
        *.tmp
        *.swp
        .DS_Store
        """
    )


