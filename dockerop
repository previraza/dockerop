def start(args: argparse.Namespace) -> int:
    root = project_root()
    config = prepare_runtime(root)
    if getattr(args, "uppershell", False):
        config["uppershell_enabled"] = True
        us_socket = str(dockerop_dir(root) / DEFAULT_UPPERSHELL_SOCKET_PROJECT.lstrip("./"))
        config.setdefault("uppershell_socket", us_socket)
        save_config(root, config)
        write_runtime_files(root, config, force=True)

    if not getattr(args, "no_banner", False):
        print_banner(config, root)

    compose_file = dockerop_dir(root) / "compose.yaml"
    command = docker_compose_command()
    run_command = command + ["-f", str(compose_file), "run", "--rm", "--workdir", "/workspace"]
    if getattr(args, "no_build", False):
        run_command.append("--no-build")
    run_command.append("opencode")
    session_id = getattr(args, "session", None)
    if session_id:
        run_command += ["-s", session_id]
    override = getattr(args, "command", None)
    if override:
        run_command += override
    return subprocess.call(run_command, cwd=root)


def prepare_runtime(root: Path) -> dict:
    if not config_path(root).exists():
        init(argparse.Namespace(force=False, quiet=True))

    config = load_config(root)
    if sync_project_root(root, config):
        save_config(root, config)
    write_runtime_files(root, config, force=True)
    return config


def shell(args: argparse.Namespace) -> int:
    root = project_root()
    if getattr(args, "uppershell", False):
        config = require_initialized(root)
        config["uppershell_enabled"] = True
        us_socket = str(dockerop_dir(root) / DEFAULT_UPPERSHELL_SOCKET_PROJECT.lstrip("./"))
        config.setdefault("uppershell_socket", us_socket)
        save_config(root, config)
        write_runtime_files(root, config, force=True)
    shell_command = getattr(args, "command", None)
    if shell_command:
        return shell_run(root, "-lc", 'exec "$@"', "sh", *shell_command)
    return shell_run(root, "-lc", "command -v bash >/dev/null 2>&1 && exec bash || exec sh")


def shell_run(root: Path, *args: str) -> int:
    prepare_runtime(root)
    compose_file = dockerop_dir(root) / "compose.yaml"
    command = docker_compose_command()
    run_command = command + [
        "-f",
        str(compose_file),
        "run",
        "--rm",
        "--workdir",
        "/workspace",
        "--entrypoint",
        "sh",
        "opencode",
        *args,
    ]
    return subprocess.call(run_command, cwd=root)


def compose_call(root: Path, *args: str) -> int:
    compose_file = dockerop_dir(root) / "compose.yaml"
    command = docker_compose_command() + ["-f", str(compose_file), *args]
    return subprocess.call(command, cwd=root)


def status(args: argparse.Namespace) -> int:
    root = project_root()
    if not config_path(root).exists():
        print("dockerop is not initialized")
        return 1
    config = load_config(root)
    if getattr(args, "json", False):
        print(json.dumps(config, indent=2))
        return 0

    state_dir = dockerop_dir(root) / "state"
    print(f"project:      {config['project_name']}")
    print(f"root:         {config['project_root']}")
    print(f"machine_id:   {config['machine_id']}")
    print(f"method:       {config.get('install_method', 'image')}")
    print(f"network:      {config.get('network_mode', DEFAULT_NETWORK_MODE)}")
    print(f"sessions:     {config.get('session_mode', DEFAULT_SESSION_MODE)}")
    print(f"image:        {display_image(config)}")
    print(f"container:    {config['container_name']}")
    print(f"state:        {state_dir}")
    print("container_cwd:/workspace")
    return 0


def config_command(_: argparse.Namespace) -> int:
    root = project_root()
    require_initialized(root)
    return compose_call(root, "config")


def build(_: argparse.Namespace) -> int:
    root = project_root()
    require_initialized(root)
    return compose_call(root, "build")


def use_method(args: argparse.Namespace) -> int:
    root = project_root()
    config = require_initialized(root)
    old_method = config.get("install_method", DEFAULT_INSTALL_METHOD)
    config["install_method"] = args.method
    config.setdefault("opencode_image", DEFAULT_OPENCODE_IMAGE)
    save_config(root, config)
    write_runtime_files(root, config, force=True)
    print(f"method: {old_method} -> {args.method}")
    print(f"machine_id preserved: {config['machine_id']}")
    return 0


def network(args: argparse.Namespace) -> int:
    if args.mode == "auto":
        return network_auto(args)
    set_network_mode(args.mode)
    return 0


def set_network_mode(mode: str) -> None:
    root = project_root()
    config = require_initialized(root)
    old_mode = config.get("network_mode", DEFAULT_NETWORK_MODE)
    config["network_mode"] = mode
    save_config(root, config)
    write_runtime_files(root, config, force=True)
    print(f"network: {old_mode} -> {mode}")
    if mode == "host":
        print("host network works on Linux Docker hosts")


def network_auto(_: argparse.Namespace) -> int:
    root = project_root()
    require_initialized(root)
    print("checking bridge network...")
    set_network_mode("bridge")
    if run_netcheck(root) == 0:
        print("bridge network works")
        return 0

    if sys.platform.startswith("linux"):
        print("bridge failed; trying host network...")
        set_network_mode("host")
        if run_netcheck(root) == 0:
            print("host network works; keeping network_mode=host")
            return 0

    print("network check failed")
    print("host firewall, Docker daemon networking, or provider rules may block container egress")
    return 1


def sessions(args: argparse.Namespace) -> int:
    root = project_root()
    config = require_initialized(root)
    old_mode = config.get("session_mode", DEFAULT_SESSION_MODE)
    config["session_mode"] = args.mode
    save_config(root, config)
    write_runtime_files(root, config, force=True)
    print(f"sessions: {old_mode} -> {args.mode}")
    if args.mode == "host":
        print(f"host config: {Path.home() / '.config' / 'opencode'}")
        print(f"host data:   {Path.home() / '.local' / 'share' / 'opencode'}")
    return 0


def netcheck(_: argparse.Namespace) -> int:
    return run_netcheck(project_root())


def run_netcheck(root: Path) -> int:
    script = netcheck_script()
    return shell_run(root, "-lc", script)


def netcheck_script() -> str:
    return textwrap.dedent(
        """\
        set -u
        echo "network_mode=${DOCKEROP_NETWORK_MODE:-unknown}"
        echo "machine_id=$(cat /etc/machine-id 2>/dev/null || true)"
        echo
        echo "resolv.conf:"
        cat /etc/resolv.conf
        echo
        echo "dns github.com:"
        if command -v getent >/dev/null 2>&1; then
          getent hosts github.com || true
        elif command -v nslookup >/dev/null 2>&1; then
          nslookup github.com || true
        else
          echo "no dns lookup tool available"
        fi
        echo
        echo "https github.com:"
        if command -v wget >/dev/null 2>&1; then
          if command -v timeout >/dev/null 2>&1; then
            timeout 12 wget -T 8 -S --spider https://github.com 2>&1
          else
            wget -T 8 -S --spider https://github.com 2>&1
          fi
        elif command -v curl >/dev/null 2>&1; then
          curl --connect-timeout 8 --max-time 12 -I https://github.com
        else
          echo "no wget or curl available"
          exit 2
        fi
        """
    )


def stop(_: argparse.Namespace) -> int:
    root = project_root()
    require_initialized(root)
    return compose_call(root, "down", "--remove-orphans")


def reset(args: argparse.Namespace) -> int:
    root = project_root()
    config = require_initialized(root)
    state_dir = dockerop_dir(root) / "state"
    if args.target == "machineId":
        old_id = config["machine_id"]
        new_id = random_machine_id()
        config["machine_id"] = new_id
        save_config(root, config)
        (state_dir / "machine-id").write_text(new_id + "\n", encoding="utf-8")
        write_runtime_files(root, config, force=True)
        print(f"machine_id: {old_id} -> {new_id}")
        return 0
    if not args.yes and not confirm(f"remove state for {config['project_name']}?"):
        print("aborted")
        return 1

    stop(argparse.Namespace())
    if state_dir.exists():
        shutil.rmtree(state_dir)
    for directory in ("home", "config", "cache", "data", "npm"):
        (state_dir / directory).mkdir(parents=True, exist_ok=True)
    (state_dir / "machine-id").write_text(config["machine_id"] + "\n", encoding="utf-8")
    print("state reset")
    return 0


def destroy(args: argparse.Namespace) -> int:
    root = project_root()
    config = require_initialized(root)
    app_dir = dockerop_dir(root)
    if not args.yes and not confirm(f"destroy {APP_DIR}/ for {config['project_name']}?"):
        print("aborted")
        return 1

    if args.image:
        subprocess.call(docker_compose_command() + ["-f", str(app_dir / "compose.yaml"), "down", "--rmi", "local"], cwd=root)
    else:
        stop(argparse.Namespace())
    shutil.rmtree(app_dir)
    print(f"removed {APP_DIR}/")
    return 0


def doctor(_: argparse.Namespace) -> int:
    root = project_root()
    ok = True
    print(f"dockerop: {VERSION}")
    print(f"project:  {root}")
    docker = shutil.which("docker")
    if docker:
        print(f"docker:   {docker}")
    else:
        print("docker:   missing")
        ok = False

    if config_path(root).exists():
        print(f"config:   {config_path(root)}")
        if docker:
            ok = compose_call(root, "config", "--quiet") == 0 and ok
    else:
        print("config:   not initialized")
    return 0 if ok else 1


def version(_: argparse.Namespace) -> int:
    print(f"dockerop {VERSION}")
    return 0


def install(args: argparse.Namespace) -> int:
    source = Path(__file__).resolve()
    target_dir = Path(args.target).expanduser().resolve()
    target = target_dir / "dockerop"
    target_dir.mkdir(parents=True, exist_ok=True)

    if target.exists() or target.is_symlink():
        if not args.force:
            raise RuntimeError(f"{target} already exists; use --force to replace it")
        target.unlink()

    if args.copy:
        shutil.copy2(source, target)
        target.chmod(0o755)
    else:
        target.symlink_to(source)

    print(f"installed {target}")
    print(f"run: export PATH=\"{target_dir}:$PATH\"")
    return 0


def confirm(question: str) -> bool:
    if not sys.stdin.isatty():
        return False
    answer = input(f"{question} [y/N] ").strip().lower()
    return answer in ("y", "yes", "o", "oui")


def help_command(_: argparse.Namespace) -> int:
    build_parser().print_help()
    return 0


GITHUB_RAW_URL = "https://raw.githubusercontent.com/previraza/dockerop/main/dockerop"
GITHUB_VERSION_URL = "https://raw.githubusercontent.com/previraza/dockerop/main/VERSION"


def fetch_remote_version() -> str | None:
    try:
        with urllib.request.urlopen(GITHUB_VERSION_URL, timeout=10) as resp:
            return resp.read().decode("utf-8").strip()
    except Exception:
        return None


def fetch_remote_script() -> str | None:
    try:
        with urllib.request.urlopen(GITHUB_RAW_URL, timeout=30) as resp:
            return resp.read().decode("utf-8")
    except Exception:
        return None


def compare_versions(current: str, remote: str) -> int:
    def parse(v: str) -> tuple[int, ...]:
        return tuple(int(p) for p in v.split(".") if p.isdigit())
    return (parse(remote) > parse(current)) - (parse(remote) < parse(current))


def update_command(args: argparse.Namespace) -> int:
    print(f"current version: {VERSION}")
    remote_version = fetch_remote_version()
    if remote_version is None:
        print("could not fetch remote version", file=sys.stderr)
        return 1
    print(f"remote version:  {remote_version}")
    cmp = compare_versions(VERSION, remote_version)
    if cmp <= 0 and not args.force:
        print("already up to date")
        return 0
    if cmp <= 0:
        print("forcing update...")
    remote_script = fetch_remote_script()
    if remote_script is None:
        print("could not download remote script", file=sys.stderr)
        return 1
    target = Path(__file__).resolve()
    backup = target.with_suffix(target.suffix + ".bak")
    try:
        shutil.copy2(target, backup)
        target.write_text(remote_script, encoding="utf-8")
        target.chmod(0o755)
    except Exception as exc:
        print(f"update failed: {exc}", file=sys.stderr)
        if backup.exists():
            shutil.copy2(backup, target)
            print("restored from backup")
        return 1
    finally:
        if backup.exists():
            backup.unlink()
    print(f"updated {target} to {remote_version}")
    return 0


def build_parser() -> argparse.ArgumentParser:
    examples = textwrap.dedent(
        """\
        examples:
          dockerop                 start OpenCode in this project
          dockerop init            create .dockerop/
          dockerop start -- --help pass arguments to OpenCode
          dockerop status          show project state
          dockerop destroy --yes   remove .dockerop/
        """
    )
    parser = argparse.ArgumentParser(
        prog="dockerop",
        description="Run OpenCode in an isolated Docker machine for the current project.",
        epilog=examples,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--version", action="store_true", help="show dockerop version")
    parser.add_argument("-s", "--session", help="start OpenCode with a session id")
    parser.add_argument("-us", "--uppershell", action="store_true", help="mount UpperShell socket into the container")
    subparsers = parser.add_subparsers(dest="command")

    init_parser = subparsers.add_parser("init", aliases=["i"], help=f"create {APP_DIR}/ configuration")
    init_parser.add_argument("--force", action="store_true", help="rewrite generated files")
    init_parser.add_argument(
        "--method",
        choices=("image", "npm", "install-script"),
        default=DEFAULT_INSTALL_METHOD,
        help="OpenCode install method for generated Docker config",
    )
    init_parser.add_argument("-q", "--quiet", action="store_true", help="only print errors")
    init_parser.set_defaults(func=init)

    start_parser = subparsers.add_parser("start", aliases=["run", "s"], help="start OpenCode in Docker")
    start_parser.add_argument("--no-build", action="store_true", help="do not build the Docker image")
    start_parser.add_argument("--no-banner", action="store_true", help="do not print dockerop launch banner")
    start_parser.add_argument("-s", "--session", help="start OpenCode with a session id")
    start_parser.add_argument("command", nargs=argparse.REMAINDER, help="optional command passed after opencode")
    start_parser.set_defaults(func=start)

    shell_parser = subparsers.add_parser("shell", aliases=["sh"], help="open a shell in the dockerop container")
    shell_parser.add_argument("-us", "--uppershell", action="store_true", help="mount UpperShell socket into the container")
    shell_parser.add_argument(
        "command",
        nargs=argparse.REMAINDER,
        help="optional command to run instead of an interactive shell",
    )
    shell_parser.set_defaults(func=shell)

    build_parser_cmd = subparsers.add_parser("build", help="build the OpenCode Docker image")
    build_parser_cmd.set_defaults(func=build)

    use_parser = subparsers.add_parser("use", help="switch OpenCode install method without resetting state")
    use_parser.add_argument("method", choices=("image", "npm", "install-script"))
    use_parser.set_defaults(func=use_method)

    network_parser = subparsers.add_parser("network", help="switch Docker network mode")
    network_parser.add_argument("mode", choices=("bridge", "host", "auto"))
    network_parser.set_defaults(func=network)

    sessions_parser = subparsers.add_parser("sessions", help="switch OpenCode session storage")
    sessions_parser.add_argument("mode", choices=("isolated", "host"))
    sessions_parser.set_defaults(func=sessions)

    netcheck_parser = subparsers.add_parser("netcheck", help="check DNS and HTTPS from the container")
    netcheck_parser.set_defaults(func=netcheck)

    stop_parser = subparsers.add_parser("stop", aliases=["down"], help="stop Docker resources without deleting state")
    stop_parser.set_defaults(func=stop)

    destroy_parser = subparsers.add_parser("destroy", aliases=["rm"], help=f"remove {APP_DIR}/ and Docker resources")
    destroy_parser.add_argument("-y", "--yes", action="store_true", help="skip confirmation")
    destroy_parser.add_argument("--image", action="store_true", help="also remove the local generated image")
    destroy_parser.set_defaults(func=destroy)

    reset_parser = subparsers.add_parser("reset", help="reset state or machine id")
    reset_parser.add_argument("target", nargs="?", default="state", choices=("state", "machineId"), help="what to reset: state (default) or machineId")
    reset_parser.add_argument("-y", "--yes", action="store_true", help="skip confirmation")
    reset_parser.set_defaults(func=reset)

    status_parser = subparsers.add_parser("status", aliases=["ps"], help="show current dockerop config")
    status_parser.add_argument("--json", action="store_true", help="print raw JSON config")
    status_parser.set_defaults(func=status)

    config_parser = subparsers.add_parser("config", help="print resolved Docker Compose config")
    config_parser.set_defaults(func=config_command)

    doctor_parser = subparsers.add_parser("doctor", help="check Docker and project configuration")
    doctor_parser.set_defaults(func=doctor)

    install_parser = subparsers.add_parser("install", help="install dockerop in PATH")
    install_parser.add_argument(
        "--target",
        default=str(Path.home() / ".local" / "bin"),
        help="target directory, default: ~/.local/bin",
    )
    install_parser.add_argument("--copy", action="store_true", help="copy instead of symlink")
    install_parser.add_argument("--force", action="store_true", help="replace an existing dockerop command")
    install_parser.set_defaults(func=install)

    version_parser = subparsers.add_parser("version", aliases=["v"], help="show dockerop version")
    version_parser.set_defaults(func=version)

    update_parser = subparsers.add_parser("update", help="update dockerop to the latest version")
    update_parser.add_argument("--force", action="store_true", help="force update even if version matches")
    update_parser.set_defaults(func=update_command)

    help_parser = subparsers.add_parser("help", aliases=["?"], help="show this help")
    help_parser.set_defaults(func=help_command)

    parser.set_defaults(func=start)
    return parser


def normalize_help_aliases(argv: list[str]) -> list[str]:
    return ["--help" if arg in ("--h", "-?", "?") else arg for arg in argv]


def main() -> int:
    parser = build_parser()
    if any(arg in ("--version", "-V") for arg in sys.argv[1:]):
        return version(argparse.Namespace())
    args = parser.parse_args(normalize_help_aliases(sys.argv[1:]))

    try:
        return args.func(args)
    except KeyboardInterrupt:
        return 130
    except RuntimeError as error:
        print(f"dockerop: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
