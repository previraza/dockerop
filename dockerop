    state_dir = dockerop_dir(root) / "state"
    banner = textwrap.dedent(
        f"""\

          _            _                          
         | |          | |                         
       __| | ___   ___| | _____ _ __ ___  _ __   
      / _` |/ _ \\ / __| |/ / _ \\ '__/ _ \\| '_ \\  
     | (_| | (_) | (__|   <  __/ | | (_) | |_) | 
      \\__,_|\\___/ \\___|_|\\_\\___|_|  \\___/| .__/  
                                          | |     
                                          |_|     

      dockerop {VERSION}
      project    {config["project_name"]}
      machine    {config["machine_id"]}
      workspace  {root} -> /workspace
