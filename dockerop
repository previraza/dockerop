#!/usr/bin/env python3
import argparse
import hashlib
import json
import os
import secrets
import shutil
import subprocess
import sys
import textwrap
import urllib.error
import urllib.request
from datetime import datetime
from pathlib import Path


APP_DIR = ".dockerop"
CONFIG_FILE = "config.json"
VERSION = "0.4.0"
DEFAULT_OPENCODE_IMAGE = "ghcr.io/anomalyco/opencode"
DEFAULT_INSTALL_METHOD = "image"
DEFAULT_NETWORK_MODE = "bridge"
DEFAULT_SESSION_MODE = "isolated"

# Uppershell defaults
DEFAULT_UPPERSHELL_SOCKET_PROJECT = "./state/uppershelld.sock"
DEFAULT_UPPERSHELL_SOCKET_SYSTEM = "/run/uppershelld.sock"


def project_root() -> Path:
    return Path.cwd().resolve()


def dockerop_dir(root: Path) -> Path:
    return root / APP_DIR


def config_path(root: Path) -> Path:
    return dockerop_dir(root) / CONFIG_FILE


def short_hash(value: str, size: int = 10) -> str:
    return hashlib.sha256(value.encode("utf-8")).hexdigest()[:size]


def slug(value: str) -> str:
    clean = "".join(char.lower() if char.isalnum() else "-" for char in value)
    clean = "-".join(part for part in clean.split("-") if part)
    return clean[:32] or "project"


def random_machine_id() -> str:
    return secrets.token_hex(16)


def host_ids() -> tuple[int | None, int | None]:
    if hasattr(os, "getuid") and hasattr(os, "getgid"):
        return os.getuid(), os.getgid()
    return None, None


def yaml_quote(value: str | Path) -> str:
    return "'" + str(value).replace("'", "''") + "'"


def load_config(root: Path) -> dict:
    with config_path(root).open("r", encoding="utf-8") as handle:
        return json.load(handle)


def write_file(path: Path, content: str, force: bool) -> None:
    if path.exists() and not force:
        return
    path.write_text(content, encoding="utf-8")


def ensure_gitignore(root: Path) -> None:
    gitignore = root / ".gitignore"
    entry = f"{APP_DIR}/\n"
    if gitignore.exists():
        content = gitignore.read_text(encoding="utf-8")
        if any(line.strip() == f"{APP_DIR}/" for line in content.splitlines()):
            return
        if content and not content.endswith("\n"):
            content += "\n"
        gitignore.write_text(content + entry, encoding="utf-8")
    else:
        gitignore.write_text(entry, encoding="utf-8")


def dockerop_gitignore() -> str:
    return textwrap.dedent(
        """\
        # Local dockerop runtime state.
        state/
        *.log
        *.tmp
        *.swp
        .DS_Store
        """
    )


def dockerfile(method: str) -> str:
    if method == "install-script":
        base_image = "debian:bookworm-slim"
        package_lines = [
            "RUN apt-get update \\",
            "    && apt-get install -y --no-install-recommends \\",
            "        bash \\",
            "        ca-certificates \\",
            "        curl \\",
            "        git \\",
            "        openssh-client \\",
            "    && rm -rf /var/lib/apt/lists/*",
            "",
        ]
        install_command = "curl -fsSL https://opencode.ai/install | bash"
    else:
        base_image = "node:22-bookworm"
        package_lines = []
        install_command = "npm install -g opencode-ai"

    lines = [
        f"FROM {base_image}",
        "",
        "ARG USER_ID=1000",
        "ARG GROUP_ID=1000",
        "",
        *package_lines,
        f"RUN {install_command}",
        "",
        'RUN if [ "${USER_ID}" = "0" ]; then \\',
        "        mkdir -p /home/opencode; \\",
        "    else \\",
        '        if ! getent group "${GROUP_ID}" >/dev/null; then \\',
        '            groupadd --gid "${GROUP_ID}" opencode; \\',
        "        fi; \\",
        '        useradd --uid "${USER_ID}" --gid "${GROUP_ID}" --create-home --shell /bin/bash opencode; \\',
        "    fi",
        "",
        "WORKDIR /workspace",
        "",
        "ENV HOME=/home/opencode",
        "ENV XDG_CONFIG_HOME=/home/opencode/.config",
        "ENV XDG_CACHE_HOME=/home/opencode/.cache",
        "ENV XDG_DATA_HOME=/home/opencode/.local/share",
        "",
        'CMD ["opencode"]',
    ]
    return "\n".join(lines) + "\n"


def compose(config: dict) -> str:
    uid, gid = host_ids()
    method = config.get("install_method", DEFAULT_INSTALL_METHOD)
    session_mode = config.get("session_mode", DEFAULT_SESSION_MODE)
    project_root_path = config["project_root"]
    if session_mode == "host":
        config_mount = f"{Path.home() / '.config' / 'opencode'}:/home/opencode/.config/opencode"
        data_mount = f"{Path.home() / '.local' / 'share' / 'opencode'}:/home/opencode/.local/share/opencode"
        cache_mount = f"{Path.home() / '.cache' / 'opencode'}:/home/opencode/.cache/opencode"
    else:
        config_mount = "./state/config:/home/opencode/.config"
        data_mount = "./state/data:/home/opencode/.local/share"
        cache_mount = "./state/cache:/home/opencode/.cache"
    lines = [
        "services:",
        "  opencode:",
    ]
    if method == "image":
        lines.append(f"    image: {config.get('opencode_image', DEFAULT_OPENCODE_IMAGE)}")
    else:
        lines.extend(
            [
                "    build:",
                "      context: .",
                "      dockerfile: Dockerfile",
                f"    image: {config['image_name']}",
            ]
        )
        if uid is not None and gid is not None:
            lines[lines.index("    image: " + config["image_name"]):lines.index("    image: " + config["image_name"])] = [
                "      args:",
                f'        USER_ID: "{uid}"',
                f'        GROUP_ID: "{gid}"',
            ]
    network_mode = config.get("network_mode", DEFAULT_NETWORK_MODE)
    if network_mode != "bridge":
        lines.append(f"    network_mode: {network_mode}")
    lines.extend(
        [
            f"    container_name: {config['container_name']}",
            "    working_dir: /workspace",
            "    stdin_open: true",
            "    tty: true",
            "    environment:",
            '      DOCKEROP: "1"',
            f'      DOCKEROP_INSTALL_METHOD: "{method}"',
            f'      DOCKEROP_NETWORK_MODE: "{network_mode}"',
            f'      DOCKEROP_SESSION_MODE: "{session_mode}"',
            f'      DOCKEROP_MACHINE_ID: "{config["machine_id"]}"',
            "      HOME: /home/opencode",
            "      XDG_CONFIG_HOME: /home/opencode/.config",
            "      XDG_CACHE_HOME: /home/opencode/.cache",
            "      XDG_DATA_HOME: /home/opencode/.local/share",
            "    volumes:",
            "      - type: bind",
            f"        source: {yaml_quote(project_root_path)}",
            "        target: /workspace",
            "      - type: bind",
            "        source: './state/home'",
            "        target: /home/opencode",
            *volume_mount(config_mount),
            *volume_mount(cache_mount),
            *volume_mount(data_mount),
            "      - type: bind",
            "        source: './state/npm'",
            "        target: /home/opencode/.npm",
            "      - type: bind",
            "        source: './state/machine-id'",
            "        target: /etc/machine-id",
            "        read_only: true",
        ]
    )
    if config.get("uppershell_enabled"):
        us_socket = config.get("uppershell_socket", DEFAULT_UPPERSHELL_SOCKET_PROJECT)
        lines.extend([
            "      - type: bind",
            f"        source: {yaml_quote(us_socket)}",
            "        target: /var/run/uppershelld.sock",
        ])
    if uid is not None and gid is not None:
        insert_at = lines.index("    stdin_open: true")
        lines.insert(insert_at, f'    user: "{uid}:{gid}"')
    return "\n".join(lines) + "\n"


def volume_mount(short_mount: str) -> list[str]:
    source, target = short_mount.rsplit(":", 1)
    return [
        "      - type: bind",
        f"        source: {yaml_quote(source)}",
        f"        target: {target}",
    ]


def info(message: str, quiet: bool = False) -> None:
    if not quiet:
        print(message)


def require_initialized(root: Path) -> dict:
    if not config_path(root).exists():
        raise RuntimeError("dockerop is not initialized; run `dockerop init` first")
    return load_config(root)


def install_method(args: argparse.Namespace) -> str:
    return getattr(args, "method", DEFAULT_INSTALL_METHOD)


def display_image(config: dict) -> str:
    if config.get("install_method", DEFAULT_INSTALL_METHOD) == "image":
        return config.get("opencode_image", DEFAULT_OPENCODE_IMAGE)
    return config["image_name"]


def sync_project_root(root: Path, config: dict) -> bool:
    current_root = str(root)
    if config.get("project_root") == current_root:
        return False
    config["project_root"] = current_root
    config["project_name"] = slug(root.name)
    return True


def save_config(root: Path, config: dict) -> None:
    config_path(root).write_text(json.dumps(config, indent=2) + "\n", encoding="utf-8")


def write_runtime_files(root: Path, config: dict, force: bool) -> None:
    app_dir = dockerop_dir(root)
    if config.get("session_mode", DEFAULT_SESSION_MODE) == "host":
        for path in (
            Path.home() / ".config" / "opencode",
            Path.home() / ".local" / "share" / "opencode",
            Path.home() / ".cache" / "opencode",
        ):
            path.mkdir(parents=True, exist_ok=True)
    dockerfile_path = app_dir / "Dockerfile"
    if config["install_method"] == "image":
        if dockerfile_path.exists():
            dockerfile_path.unlink()
    else:
        write_file(dockerfile_path, dockerfile(config["install_method"]), force)
    write_file(app_dir / "compose.yaml", compose(config), force)
    write_file(app_dir / ".gitignore", dockerop_gitignore(), force)


def init(args: argparse.Namespace) -> int:
    root = project_root()
    app_dir = dockerop_dir(root)
    app_dir.mkdir(exist_ok=True)
    state_dir = app_dir / "state"
    for directory in ("home", "config", "cache", "data", "npm"):
        (state_dir / directory).mkdir(parents=True, exist_ok=True)

    config_exists = config_path(root).exists()
    if config_exists and not args.force:
        config = load_config(root)
    else:
        project_id = short_hash(str(root))
        project_name = slug(root.name)
        config = {
            "version": 1,
            "project_root": str(root),
            "project_name": project_name,
            "project_id": project_id,
            "machine_id": random_machine_id(),
            "install_method": install_method(args),
            "network_mode": DEFAULT_NETWORK_MODE,
            "session_mode": DEFAULT_SESSION_MODE,
            "opencode_image": DEFAULT_OPENCODE_IMAGE,
            "image_name": f"dockerop-opencode-{project_id}",
            "container_name": f"dockerop-{project_name}-{project_id[:8]}",
        }
        save_config(root, config)
    config.setdefault("install_method", DEFAULT_INSTALL_METHOD)
    config.setdefault("network_mode", DEFAULT_NETWORK_MODE)
    config.setdefault("session_mode", DEFAULT_SESSION_MODE)
    config.setdefault("opencode_image", DEFAULT_OPENCODE_IMAGE)

    machine_id_path = state_dir / "machine-id"
    if args.force or not machine_id_path.exists():
        machine_id_path.write_text(config["machine_id"] + "\n", encoding="utf-8")

    write_runtime_files(root, config, args.force)
    ensure_gitignore(root)

    quiet = getattr(args, "quiet", False)
    info(f"initialized {APP_DIR}/", quiet)
    info(f"machine_id={config['machine_id']}", quiet)
    return 0


def docker_compose_command() -> list[str]:
    docker = shutil.which("docker")
    if not docker:
        raise RuntimeError("docker is not installed or not available in PATH")
    return [docker, "compose"]


